{
  "name": "carousel-gen-root",
  "version": "1.0.0",
  "description": "AI-Powered Instagram Carousel Generation Engine",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" --filter \"./apps/*\" build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.5",
    "eslint": "^9.5.0",
    "@eslint/js": "^9.5.0",
    "globals": "^15.6.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "prettier": "^3.3.2",
    "vitest": "^1.6.0"
  }
}
